# Redis (연결 수명만 — 데이터 진실원천은 SQLite)
REDIS_URL=redis://localhost:6379

# SQLite 영속 DB (도커는 named volume /data 마운트, 재기동 무손실)
DB_PATH=/data/news.db

# DART Open API (https://opendart.fss.or.kr 에서 발급)
DART_API_KEY=

# 크롤링 주기 (초)
CRAWL_INTERVAL_NEWS=300
CRAWL_INTERVAL_DISCLOSURE=60

# 로그 레벨
LOG_LEVEL=INFO

# 서버 설정
HOST=0.0.0.0
PORT=8000
WORKERS=1
